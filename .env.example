# =============================================================================
# Environment Variables for Eduitit
# Copy this file to .env and fill in the values
# =============================================================================

# Django Settings
DJANGO_SETTINGS_MODULE=config.settings_production

# Security (generate a strong key for production!)
# python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=your-secret-key-here

# Debug Mode (set to False in production)
DJANGO_DEBUG=False

# Allowed Hosts (comma-separated)
DJANGO_ALLOWED_HOSTS=.onrender.com,localhost,127.0.0.1

# Home layout rollout
# v2 keeps the current login home. Set to v4 only when the new layout is ready.
HOME_LAYOUT_VERSION=v2

# =============================================================================
# AI API Keys
# =============================================================================
GEMINI_API_KEY=your-gemini-api-key-here
KAKAO_JS_KEY=your-kakao-js-key-here
LAW_API_OC=
TEACHER_LAW_ENABLED=False
TEACHER_LAW_DAILY_LIMIT_PER_USER=20
TEACHER_LAW_TOTAL_TIMEOUT_SECONDS=20
TEACHER_LAW_SEARCH_TIMEOUT_SECONDS=4
TEACHER_LAW_DETAIL_TIMEOUT_SECONDS=4
TEACHER_LAW_LLM_TIMEOUT_SECONDS=12
TEACHER_LAW_SEARCH_RESULT_LIMIT=5
TEACHER_LAW_DETAIL_FETCH_LIMIT=3
TEACHER_LAW_FAQ_CACHE_TTL_SECONDS=43200

# =============================================================================
# Padlet API (Optional - for real-time sync)
# Get from: https://padlet.com/settings/developer (Pro/Team required)
# =============================================================================
PADLET_API_KEY=your-padlet-api-key-here

# =============================================================================
# External Calendar / Webhook Integration
# Either EDUITIT_API_KEY or HOOK_TOKEN can be used for the same external token.
# Webhook receiver header: X-Hook-Token
# =============================================================================
EDUITIT_API_KEY=your-external-calendar-token
HOOK_TOKEN=
EDUITIT_EXTERNAL_CALENDAR_USERNAME=user694
EDUITIT_EXTERNAL_CALENDAR_PROVIDER=naver

# =============================================================================
# Quickdrop Personal External API
# Fixed target owner: user694
# =============================================================================
QUICKDROP_EXTERNAL_API_KEY=your-quickdrop-personal-api-key

# =============================================================================
# Database (Neon PostgreSQL)
# Get this from your Neon dashboard: https://console.neon.tech
# =============================================================================
DATABASE_URL=postgresql://user:password@host/database?sslmode=require
# Optional IPv4 override when the runtime cannot reach IPv6 addresses.
# Keep DATABASE_URL host as the Neon hostname and only set one of these if needed.
# DATABASE_HOSTADDR=1.2.3.4
# DATABASE_PREFER_IPV4=True

# =============================================================================
# Cloudinary (이미지 클라우드 저장소)
# Get from: https://cloudinary.com/console (무료 25GB)
# =============================================================================
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# =============================================================================
# Sheetbook Rollout Flags
# =============================================================================
SHEETBOOK_ENABLED=False
# Optional beta allowlist (comma-separated)
SHEETBOOK_BETA_USERNAMES=
SHEETBOOK_BETA_EMAILS=
SHEETBOOK_BETA_USER_IDS=
# Default class duration used when end time is missing (minutes)
SHEETBOOK_SCHEDULE_DEFAULT_DURATION_MINUTES=50
# 1교시 시작 시각(24h, 예: 9 -> 09:00)
SHEETBOOK_PERIOD_FIRST_CLASS_HOUR=9
# 1교시 시작 분(예: 10 -> 09:10 시작)
SHEETBOOK_PERIOD_FIRST_CLASS_MINUTE=0
# Grid bulk save batch size (50~2000)
SHEETBOOK_GRID_BULK_BATCH_SIZE=400
# Pilot KPI target tuning
SHEETBOOK_WORKSPACE_TO_CREATE_TARGET_RATE=60
SHEETBOOK_WORKSPACE_CREATE_TO_ACTION_TARGET_RATE=50
SHEETBOOK_WORKSPACE_TO_CREATE_MIN_SAMPLE=5
SHEETBOOK_WORKSPACE_CREATE_TO_ACTION_MIN_SAMPLE=5
# Startup rollout check mode (strict fail on warning)
SHEETBOOK_ROLLOUT_STRICT_STARTUP=False
# Startup threshold recommendation run (optional)
SHEETBOOK_ROLLOUT_RECOMMEND_STARTUP=False
SHEETBOOK_ROLLOUT_RECOMMEND_DAYS=14

# =============================================================================
# ClassCalendar Message Capture Rollout Flags
# =============================================================================
FEATURE_MESSAGE_CAPTURE_ENABLED=False
# Optional allowlist (comma-separated): keep empty to disable all users
FEATURE_MESSAGE_CAPTURE_ALLOWLIST_USERNAMES=
FEATURE_MESSAGE_CAPTURE_ALLOWLIST_EMAILS=
FEATURE_MESSAGE_CAPTURE_ALLOWLIST_USER_IDS=
